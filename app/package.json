{
  "name": "agentconnector-app",
  "version": "0.1.0",
  "description": "Desktop control panel for AgentConnector (you are the director).",
  "author": "ZoyLuo",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "build:engine": "cd .. && npm run build",
    "predev": "npm run build:engine",
    "dev": "electron-vite dev",
    "prebuild": "npm run build:engine",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --mac --dir",
    "postdist": "codesign --deep --force --sign - --identifier com.zoyluo.agentconnector 'release/mac-arm64/AgentConnector.app' && echo 'ad-hoc signed -> release/mac-arm64/AgentConnector.app (drag to /Applications)'",
    "dist:dmg": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "diff2html": "3.4.56"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "^5.6.0",
    "vite": "7.3.3"
  }
}
